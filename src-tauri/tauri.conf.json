{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Aether",
  "version": "0.1.3",
  "identifier": "com.aether.research-workstation",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:19924",
    "beforeDevCommand": "node scripts/prepare-updater-config.mjs && npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Aether - 全网产品想法调研与决策系统",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 680,
        "resizable": true,
        "fullscreen": false,
        "maximized": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "msi"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "aether"
        ]
      }
    },
    "updater": {
      "endpoints": [
        "https://github.com/xtc002007/Aether/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQzNDdENTM5RDEyQjczMUQKUldRZGN5dlJPZFZIMHpjcmZWTUpqR3dlMlZBNEFWRkNzZklpRzcyRUxEZ0c2WFFBY0oxOW0vVjQK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
